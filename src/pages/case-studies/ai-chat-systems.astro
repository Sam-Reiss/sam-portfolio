<script is:inline>
	/** Show filename overlay until assets exist; hide when images load. */
	document.querySelectorAll('.case-media-slot').forEach((slot) => {
		const img = slot.querySelector('img');
		if (!img) return;
		const onLoad = () => {
			if (img.naturalWidth > 0) slot.classList.add('is-loaded');
		};
		const onError = () => {
			slot.classList.add('is-missing');
		};
		if (img.complete && img.naturalWidth > 0) onLoad();
		else {
			img.addEventListener('load', onLoad, { once: true });
			img.addEventListener('error', onError, { once: true });
		}
	});

	/** Smooth in-page scroll for case study anchor links (respects reduced motion). */
	document.querySelectorAll('a.case-anchor-link-meta[href^="#"], a.case-anchor-link-back[href^="#"]').forEach((link) => {
		link.addEventListener('click', (event) => {
			const href = link.getAttribute('href');
			if (!href || href.length < 2) return;
			const id = href.slice(1);
			const target = document.getElementById(id);
			if (!target) return;
			event.preventDefault();
			const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			target.scrollIntoView({ behavior: reduced ? 'auto' : 'smooth', block: 'start' });
			try {
				window.history.replaceState(null, '', href);
			} catch {
				/* ignore */
			}
			if (!target.hasAttribute('tabindex')) target.setAttribute('tabindex', '-1');
			requestAnimationFrame(() => {
				try {
					target.focus({ preventScroll: true });
				} catch {
					/* ignore */
				}
			});
			const onBlur = () => {
				target.removeAttribute('tabindex');
				target.removeEventListener('blur', onBlur);
			};
			target.addEventListener('blur', onBlur);
		});
	});

	/** Case study carousels: prev / next, editorial index, keyboard when focused, timed advance until user navigates. */
	document.querySelectorAll('[data-case-carousel]').forEach((root) => {
		const track = root.querySelector('[data-carousel-track]');
		const slideList = root.querySelectorAll('[data-carousel-slide]');
		const prevBtn = root.querySelector('[data-carousel-prev]');
		const nextBtn = root.querySelector('[data-carousel-next]');
		const indexCurrent = root.querySelector('[data-carousel-index-current]');
		const indexTotal = root.querySelector('[data-carousel-index-total]');
		if (!track || slideList.length === 0) return;

		const pad2 = (k) => String(k).padStart(2, '0');
		const slides = Array.from(slideList);
		const n = slides.length;
		let idx = 0;
		let autoplayIntervalId = null;
		let userPausedAutoplay = false;
		const reduceMotionMq = window.matchMedia('(prefers-reduced-motion: reduce)');

		if (indexTotal) indexTotal.textContent = pad2(n);

		function clearAutoplayTimer() {
			if (autoplayIntervalId !== null) {
				clearInterval(autoplayIntervalId);
				autoplayIntervalId = null;
			}
		}

		function stopAutoplayForUser() {
			userPausedAutoplay = true;
			clearAutoplayTimer();
		}

		function maybeStartAutoplay() {
			clearAutoplayTimer();
			if (userPausedAutoplay || n <= 1 || reduceMotionMq.matches || document.hidden) return;
			autoplayIntervalId = window.setInterval(() => {
				go(1);
			}, 8000);
		}

		function apply() {
			track.style.transform = `translateX(-${idx * 100}%)`;
			slides.forEach((el, i) => {
				const active = i === idx;
				el.classList.toggle('is-active', active);
				el.setAttribute('aria-hidden', active ? 'false' : 'true');
			});
			if (indexCurrent) indexCurrent.textContent = pad2(idx + 1);
			const pos = `slide ${idx + 1} of ${n}`;
			prevBtn?.setAttribute('aria-label', `Previous image, ${pos}`);
			nextBtn?.setAttribute('aria-label', `Next image, ${pos}`);
		}

		function go(delta) {
			idx = (idx + delta + n) % n;
			apply();
		}

		function userGo(delta) {
			stopAutoplayForUser();
			go(delta);
		}

		prevBtn?.addEventListener('click', () => userGo(-1));
		nextBtn?.addEventListener('click', () => userGo(1));

		root.addEventListener('keydown', (e) => {
			if (e.key === 'ArrowLeft') {
				e.preventDefault();
				userGo(-1);
			} else if (e.key === 'ArrowRight') {
				e.preventDefault();
				userGo(1);
			}
		});

		const onVisibility = () => {
			if (document.hidden) clearAutoplayTimer();
			else maybeStartAutoplay();
		};
		document.addEventListener('visibilitychange', onVisibility);

		const onReduceMotionChange = () => {
			if (reduceMotionMq.matches) clearAutoplayTimer();
			else maybeStartAutoplay();
		};
		if (typeof reduceMotionMq.addEventListener === 'function') {
			reduceMotionMq.addEventListener('change', onReduceMotionChange);
		} else if (typeof reduceMotionMq.addListener === 'function') {
			reduceMotionMq.addListener(onReduceMotionChange);
		}

		apply();
		maybeStartAutoplay();
	});
</script>
