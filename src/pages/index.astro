---
import Layout from '../layouts/Layout.astro';

const projects = [
	{
		id: 'project-ai-catalog',
		title: 'Vision Prototype: GitLab AI Catalog',
		description:
			'Reframed AI from a chat interface into a discoverable, composable system of capabilities.',
		meta: 'AI platform UX / Concept prototype / 2025',
		link: '/case-studies/ai-catalog-prototype'
	},
	{
		id: 'project-ai-chat',
		title: 'AI Chat Systems — IDE & Agent Platforms',
		description:
			'Designed and shipped AI chat experiences across IDE and web surfaces, spanning Watsonx Code Assistant and GitLab’s Duo Agent Platform.',
		meta: 'Shipped product / Developer tools / 2024',
		link: '/case-studies/ai-chat-systems'
	},
	{
		id: 'project-exploratory',
		title: 'Exploratory AI Work',
		description:
			'Developed forward-looking concepts for agent workflows, productivity systems, and AI-driven developer tooling.',
		meta: 'Product strategy / 0–1 concepts / 2025',
		link: '/case-studies/exploratory-ai-work'
	}
];
---

<Layout title="Sam Reiss | Portfolio">
	<main>
		<section class="intro-grid">
			<div class="identity-column">
				<p class="eyebrow">Senior Product Designer @ GitLab (formerly IBM)</p>
				<h1 class="hero-name">
					<span class="hero-line" data-scatter-text>SAM</span>
					<span class="hero-line" data-scatter-text>REISS</span>
				</h1>
			</div>

			<div class="work-column">
				<h2 class="work-heading">My Work</h2>
				<div class="project-list" data-project-list>
					{
						projects.map((project, index) => (
							<article class="project-item">
								<h3>
									<button
										class="project-trigger"
										type="button"
										aria-expanded="false"
										aria-controls={`${project.id}-panel`}
										id={`${project.id}-button`}
									>
										<span>{project.title}</span>
										<span class="caret" aria-hidden="true">⌃</span>
									</button>
								</h3>
								<div
									class="project-panel"
									id={`${project.id}-panel`}
									role="region"
									aria-labelledby={`${project.id}-button`}
								>
									<div class="project-panel-inner">
										<p class="project-description">{project.description}</p>
										<p class="project-meta">{project.meta}</p>
										<p>
											<a class="project-link" href={project.link}>Read case study</a>
										</p>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="how-grid" aria-labelledby="how-i-work-title">
			<h2 id="how-i-work-title">How I Work</h2>
			<div class="how-copy">
				<p data-scatter-text>
					I focus on AI product design, prototyping workflows, and developer tools. My
					work turns early product direction into clear interaction models teams can test,
					debate, and ship.
				</p>
				<p data-scatter-text>
					I work at the intersection of product direction and execution. I use prototypes to
					make decisions visible early, expose tradeoffs clearly, and help teams align faster
					around what to build.
				</p>
				<p data-scatter-text>
					My process stays lightweight: frame the problem, test interaction models quickly,
					then refine the strongest path with engineering constraints in view.
				</p>
			</div>
		</section>
	</main>
</Layout>

<script>
	const projectList = document.querySelector('[data-project-list]');
	const triggers = projectList?.querySelectorAll('.project-trigger') ?? [];

	const closeAllPanels = () => {
		triggers.forEach((trigger) => {
			trigger.setAttribute('aria-expanded', 'false');
			const panelId = trigger.getAttribute('aria-controls');
			const panel = panelId ? document.getElementById(panelId) : null;
			panel?.classList.remove('open');
		});
	};

	triggers.forEach((trigger) => {
		trigger.addEventListener('click', () => {
			const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
			closeAllPanels();

			if (!isExpanded) {
				trigger.setAttribute('aria-expanded', 'true');
				const panelId = trigger.getAttribute('aria-controls');
				const panel = panelId ? document.getElementById(panelId) : null;
				panel?.classList.add('open');
			}
		});
	});

	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const scatterTargets = reduceMotion ? [] : [...document.querySelectorAll('[data-scatter-text]')];

	const setupScatter = (element) => {
		const text = element.textContent ?? '';
		if (!text.trim()) return;

		element.setAttribute('aria-label', text.trim());
		element.textContent = '';

		Array.from(text).forEach((char) => {
			const span = document.createElement('span');
			span.className = char === ' ' ? 'scatter-char scatter-space' : 'scatter-char';
			span.textContent = char === ' ' ? '\u00A0' : char;
			element.append(span);
		});

		const charSpans = [...element.querySelectorAll('.scatter-char')];

		element.addEventListener('mousemove', (event) => {
			const rect = element.getBoundingClientRect();
			const pointerX = event.clientX - rect.left;
			const pointerY = event.clientY - rect.top;

			charSpans.forEach((span, index) => {
				const centerX = span.offsetLeft + span.offsetWidth / 2;
				const centerY = span.offsetTop + span.offsetHeight / 2;
				const distance = Math.hypot(pointerX - centerX, pointerY - centerY);
				const influence = Math.max(0, 1 - distance / 180);
				const seed = index * 0.73;
				const moveX = Math.sin((pointerX + seed) / 17) * 8 * influence;
				const moveY = Math.cos((pointerY + seed) / 20) * 6 * influence;
				const rotate = Math.sin((pointerX + pointerY + seed) / 24) * 9 * influence;
				span.style.transform = `translate(${moveX}px, ${moveY}px) rotate(${rotate}deg)`;
			});
		});

		element.addEventListener('mouseleave', () => {
			charSpans.forEach((span) => {
				span.style.transform = '';
			});
		});
	};

	scatterTargets.forEach(setupScatter);
</script>

<style>
	.intro-grid {
		display: grid;
		grid-template-columns: 1.58fr 0.72fr;
		gap: 5.4rem;
		align-items: start;
		padding-bottom: 0.9rem;
	}

	.eyebrow {
		color: var(--muted);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 1.35rem;
	}

	.hero-name {
		font-family: "Roboto Condensed", "Arial Narrow", "Aptos Narrow", sans-serif;
		font-size: clamp(3.5rem, 11.2vw, 9.25rem);
		font-weight: 300;
		line-height: 0.81;
		letter-spacing: -0.02em;
		text-wrap: balance;
		display: grid;
		text-transform: uppercase;
	}

	.hero-line {
		display: block;
	}

	.work-heading {
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 0.85rem;
	}

	.project-list {
		border-top: 1px solid var(--line);
	}

	.project-item {
		border-bottom: 1px solid var(--line);
	}

	.project-trigger {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		border: 0;
		background: none;
		font: inherit;
		font-size: 1rem;
		font-weight: 500;
		line-height: 1.3;
		text-align: left;
		padding: 1rem 0;
		color: var(--foreground);
		cursor: pointer;
		transition: transform 240ms cubic-bezier(0.2, 0.9, 0.2, 1), color 180ms ease;
		position: relative;
	}

	.project-trigger:hover {
		transform: translateX(2px);
		color: #070707;
	}

	.project-trigger:focus-visible {
		outline: 2px solid var(--foreground);
		outline-offset: 4px;
	}

	.caret {
		font-size: 0.8rem;
		transform: rotate(180deg);
		transition: transform 220ms ease;
	}

	.project-trigger[aria-expanded='true'] .caret {
		transform: rotate(0deg);
	}

	.project-panel {
		display: grid;
		grid-template-rows: 0fr;
		opacity: 0;
		transition:
			grid-template-rows 280ms cubic-bezier(0.22, 1, 0.36, 1),
			opacity 180ms ease;
	}

	.project-panel.open {
		grid-template-rows: 1fr;
		opacity: 1;
	}

	.project-panel-inner {
		overflow: hidden;
		padding-bottom: 1.15rem;
	}

	.project-description {
		color: #222;
		font-size: 0.96rem;
		line-height: 1.58;
		margin-bottom: 0.82rem;
	}

	.project-meta {
		color: var(--muted-strong);
		font-size: 0.77rem;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		margin-bottom: 0.92rem;
	}

	.project-link {
		font-size: 0.9rem;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.15em;
		transition: color 180ms ease, letter-spacing 180ms ease;
	}

	.project-link:hover {
		color: #000;
		letter-spacing: 0.012em;
	}

	.how-grid {
		margin-top: 8.1rem;
		padding-top: 2.8rem;
		border-top: 1px solid var(--line);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
	}

	.how-grid h2 {
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted);
	}

	.how-copy {
		display: grid;
		gap: 1.25rem;
		max-width: 65ch;
	}

	.how-copy p {
		color: #232323;
		font-size: clamp(1rem, 1.25vw, 1.1rem);
		line-height: 1.68;
		letter-spacing: -0.006em;
	}

	.scatter-char {
		display: inline-block;
		transition: transform 240ms cubic-bezier(0.2, 0.9, 0.2, 1);
		will-change: transform;
	}

	.scatter-space {
		min-width: 0.22em;
	}

	@media (max-width: 980px) {
		.intro-grid {
			grid-template-columns: 1fr;
			gap: 3.1rem;
		}

		.hero-name {
			font-size: clamp(3rem, 17vw, 5.2rem);
		}

		.how-grid {
			margin-top: 5rem;
			grid-template-columns: 1fr;
			gap: 1.3rem;
		}

	}

	@media (prefers-reduced-motion: reduce) {
		.project-trigger:hover {
			transform: none;
		}

		.caret,
		.project-panel,
		.project-trigger,
		.scatter-char {
			transition: none;
		}

	}
</style>
