---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const projects = [
	{
		id: 'project-ai-catalog',
		title: 'Vision Prototype: GitLab AI Catalog',
		description:
			'Reframed AI from a chat interface into a discoverable, composable system of capabilities.',
		meta: 'AI platform UX / Concept prototype / 2025',
		link: `${baseUrl}case-studies/ai-catalog-prototype/`
	},
	{
		id: 'project-ai-chat',
		title: 'AI Chat Systems — IDE & Agent Platforms',
		description:
			'Designed and shipped AI chat experiences across IDE and web surfaces, spanning Watsonx Code Assistant and GitLab’s Duo Agent Platform.',
		meta: 'Shipped product / Developer tools / 2024',
		link: `${baseUrl}case-studies/ai-chat-systems/`
	},
	{
		id: 'project-exploratory',
		title: 'Exploratory AI Work',
		description:
			'Developed forward-looking concepts for agent workflows, productivity systems, and AI-driven developer tooling.',
		meta: 'Product strategy / 0–1 concepts / 2025',
		link: `${baseUrl}case-studies/exploratory-ai-work/`
	}
];
---

<Layout title="Sam Reiss | Portfolio">
	<main class="home-main">
		<section class="intro-grid accent-zone accent-zone-hero">
			<div class="decorative-accent decorative-accent-arc" aria-hidden="true">
				<svg
					viewBox="0 0 560 250"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					focusable="false"
				>
					<path
						d="M38 183C67 104 132 48 218 34C310 19 392 59 445 129L385 177C351 130 293 103 231 114C173 124 130 164 108 219L38 183Z"
						fill="var(--accent-green)"
					></path>
				</svg>
			</div>
			<div class="decorative-accent decorative-accent-circle" aria-hidden="true"></div>
			<div class="identity-column">
				<p class="eyebrow" data-scatter-text>Hi, I'm Sam Reiss</p>
				<h1 class="hero-name">
					<span class="hero-line"
						>I'm a Senior Product Designer at GitLab, working on AI powered tools. Formerly
						watsonX at IBM.</span
					>
				</h1>
			</div>

			<div class="work-column">
				<h2 class="work-heading">My Work</h2>
				<div class="decorative-accent decorative-accent-plus" aria-hidden="true">
					<svg
						viewBox="0 0 44 44"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
						focusable="false"
					>
						<path
							d="M22 3C24.9 3 27.2 5.3 27.2 8.2V15.9H34.8C37.7 15.9 40 18.2 40 21.1C40 24 37.7 26.3 34.8 26.3H27.2V34C27.2 36.9 24.9 39.2 22 39.2C19.1 39.2 16.8 36.9 16.8 34V26.3H9.2C6.3 26.3 4 24 4 21.1C4 18.2 6.3 15.9 9.2 15.9H16.8V8.2C16.8 5.3 19.1 3 22 3Z"
							fill="var(--accent-red)"
						></path>
					</svg>
				</div>
				<div class="decorative-accent decorative-accent-circle-secondary" aria-hidden="true"></div>
				<div class="project-list" data-project-list>
					{
						projects.map((project, index) => (
							<article class="project-item">
								<h3>
									<button
										class="project-trigger"
										type="button"
										aria-expanded="false"
										aria-controls={`${project.id}-panel`}
										id={`${project.id}-button`}
									>
										<span>{project.title}</span>
										<span class="caret" aria-hidden="true">⌃</span>
									</button>
								</h3>
								<div
									class="project-panel"
									id={`${project.id}-panel`}
									role="region"
									aria-labelledby={`${project.id}-button`}
								>
									<div class="project-panel-inner">
										<p class="project-description">{project.description}</p>
										<p class="project-meta">{project.meta}</p>
										<p>
											<a class="project-link" href={project.link}>Read case study</a>
										</p>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="how-grid accent-zone accent-zone-how" aria-labelledby="how-i-work-title">
			<div class="decorative-accent decorative-accent-capsule" aria-hidden="true"></div>
			<div class="decorative-accent decorative-accent-oval-secondary" aria-hidden="true"></div>
			<div class="decorative-accent decorative-accent-star-secondary" aria-hidden="true">
				<svg
					viewBox="0 0 60 60"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					focusable="false"
				>
					<path
						d="M30 4L35.2 18.1L50.5 9.5L41.9 24.8L56 30L41.9 35.2L50.5 50.5L35.2 41.9L30 56L24.8 41.9L9.5 50.5L18.1 35.2L4 30L18.1 24.8L9.5 9.5L24.8 18.1L30 4Z"
						fill="var(--accent-red)"
					></path>
				</svg>
			</div>
			<h2 id="how-i-work-title">How I work</h2>
			<div class="how-copy">
				<p>
					I focus on AI product design, prototyping workflows, and developer tools. My
					work turns early product direction into clear interaction models teams can test,
					debate, and ship.
				</p>
				<p>
					I work at the intersection of product direction and execution. I use prototypes to
					make decisions visible early, expose tradeoffs clearly, and help teams align faster
					around what to build.
				</p>
				<p>
					My process stays lightweight: frame the problem, test interaction models quickly,
					then refine the strongest path with engineering constraints in view.
				</p>
			</div>
		</section>
	</main>
</Layout>

<script>
	const projectList = document.querySelector('[data-project-list]');
	const triggers = projectList?.querySelectorAll('.project-trigger') ?? [];

	const closeAllPanels = () => {
		triggers.forEach((trigger) => {
			trigger.setAttribute('aria-expanded', 'false');
			const panelId = trigger.getAttribute('aria-controls');
			const panel = panelId ? document.getElementById(panelId) : null;
			panel?.classList.remove('open');
		});
	};

	triggers.forEach((trigger) => {
		trigger.addEventListener('click', () => {
			const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
			closeAllPanels();

			if (!isExpanded) {
				trigger.setAttribute('aria-expanded', 'true');
				const panelId = trigger.getAttribute('aria-controls');
				const panel = panelId ? document.getElementById(panelId) : null;
				panel?.classList.add('open');
			}
		});
	});

	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const prefersFinePointer = window.matchMedia('(pointer: fine)').matches;
	const query = new URLSearchParams(window.location.search);
	const enableMotionDebug =
		(window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') &&
		query.has('motionDebug');
	const densityMode = query.get('density');
	const proximityOverride = query.get('proximity');

	if (enableMotionDebug) {
		document.documentElement.classList.add('motion-debug');
	}

	const homeMain = document.querySelector('.home-main');
	if (homeMain && (densityMode === 'full' || densityMode === 'reduced')) {
		homeMain.setAttribute('data-accent-density', densityMode);
	}

	const proximityEnabled =
		prefersFinePointer &&
		(enableMotionDebug || !reduceMotion) &&
		proximityOverride !== '0';

	if (homeMain && proximityEnabled) {
		const accents = [...homeMain.querySelectorAll('.decorative-accent')];
		const accentState = accents.map((element) => {
			const style = window.getComputedStyle(element);
			const radius = Number.parseFloat(style.getPropertyValue('--proximity-radius')) || 180;
			const strength = Number.parseFloat(style.getPropertyValue('--proximity-strength')) || 7;
			const ease = Number.parseFloat(style.getPropertyValue('--proximity-ease')) || 0.14;
			return {
				element,
				radius,
				strength,
				ease,
				centerX: 0,
				centerY: 0,
				currentX: 0,
				currentY: 0
			};
		});

		const pointer = { x: 0, y: 0, active: false };
		let rafId = 0;

		const refreshCenters = () => {
			accentState.forEach((accent) => {
				const rect = accent.element.getBoundingClientRect();
				accent.centerX = rect.left + rect.width * 0.5;
				accent.centerY = rect.top + rect.height * 0.5;
			});
		};

		const tick = () => {
			let hasMovement = false;

			accentState.forEach((accent) => {
				let targetX = 0;
				let targetY = 0;

				if (pointer.active) {
					const dx = accent.centerX - pointer.x;
					const dy = accent.centerY - pointer.y;
					const distance = Math.hypot(dx, dy);

					if (distance < accent.radius && distance > 0.001) {
						const normalized = 1 - distance / accent.radius;
						const push = normalized * accent.strength;
						targetX = (dx / distance) * push;
						targetY = (dy / distance) * push;
					}
				}

				accent.currentX += (targetX - accent.currentX) * accent.ease;
				accent.currentY += (targetY - accent.currentY) * accent.ease;
				accent.element.style.setProperty('--prox-x', `${accent.currentX.toFixed(2)}px`);
				accent.element.style.setProperty('--prox-y', `${accent.currentY.toFixed(2)}px`);

				if (
					Math.abs(accent.currentX - targetX) > 0.05 ||
					Math.abs(accent.currentY - targetY) > 0.05 ||
					Math.abs(accent.currentX) > 0.05 ||
					Math.abs(accent.currentY) > 0.05
				) {
					hasMovement = true;
				}
			});

			if (hasMovement || pointer.active) {
				rafId = window.requestAnimationFrame(tick);
			} else {
				rafId = 0;
			}
		};

		const requestTick = () => {
			if (!rafId) rafId = window.requestAnimationFrame(tick);
		};

		const onPointerMove = (event) => {
			pointer.x = event.clientX;
			pointer.y = event.clientY;
			pointer.active = true;
			requestTick();
		};

		const onPointerLeave = () => {
			pointer.active = false;
			requestTick();
		};

		refreshCenters();
		window.addEventListener('pointermove', onPointerMove, { passive: true });
		window.addEventListener('pointerleave', onPointerLeave);
		window.addEventListener('resize', () => {
			refreshCenters();
			requestTick();
		});
		window.addEventListener('scroll', refreshCenters, { passive: true });
	}

	const scatterTargets = reduceMotion ? [] : [...document.querySelectorAll('[data-scatter-text]')];

	const setupScatter = (element) => {
		const text = element.textContent ?? '';
		if (!text.trim()) return;

		element.setAttribute('aria-label', text.trim());
		element.textContent = '';

		Array.from(text).forEach((char) => {
			const span = document.createElement('span');
			span.className = char === ' ' ? 'scatter-char scatter-space' : 'scatter-char';
			span.textContent = char === ' ' ? '\u00A0' : char;
			span.setAttribute('aria-hidden', 'true');
			element.append(span);
		});

		const charSpans = [...element.querySelectorAll('.scatter-char')];
		const randomizeTransforms = () => {
			charSpans.forEach((span) => {
				if (span.classList.contains('scatter-space')) return;
				const moveX = (Math.random() * 2 - 1) * 4.4;
				const moveY = (Math.random() * 2 - 1) * 3.6;
				const rotate = (Math.random() * 2 - 1) * 3.8;
				const delay = Math.random() * 60;
				span.style.setProperty('--scatter-x', `${moveX.toFixed(2)}px`);
				span.style.setProperty('--scatter-y', `${moveY.toFixed(2)}px`);
				span.style.setProperty('--scatter-r', `${rotate.toFixed(2)}deg`);
				span.style.setProperty('--scatter-delay', `${delay.toFixed(0)}ms`);
			});
		};

		const resetTransforms = () => {
			charSpans.forEach((span) => {
				span.style.setProperty('--scatter-x', '0px');
				span.style.setProperty('--scatter-y', '0px');
				span.style.setProperty('--scatter-r', '0deg');
				span.style.setProperty('--scatter-delay', '0ms');
			});
		};

		const activate = () => {
			element.classList.add('scatter-active');
			randomizeTransforms();
		};

		const deactivate = () => {
			element.classList.remove('scatter-active');
			resetTransforms();
		};

		element.addEventListener('pointerenter', activate);
		element.addEventListener('mouseenter', activate);
		element.addEventListener('pointerleave', deactivate);
		element.addEventListener('mouseleave', deactivate);
	};

	scatterTargets.forEach(setupScatter);
</script>

<style>
	:root {
		--accent-green: #009f5a;
		--accent-red: #ff3b30;
		--accent-blue: #0b1b3a;
		--accent-blue-soft: #3f5f9a;
	}

	.home-main {
		width: min(1320px, calc(100% - 6rem));
		margin: 0 auto;
	}

	.home-main[data-accent-density='reduced'] .decorative-accent-circle,
	.home-main[data-accent-density='reduced'] .decorative-accent-star-secondary,
	.home-main[data-accent-density='reduced'] .decorative-accent-oval-secondary,
	.home-main[data-accent-density='reduced'] .decorative-accent-circle-secondary {
		display: none;
	}

	.accent-zone {
		position: relative;
		isolation: isolate;
	}

	.intro-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(420px, 0.75fr);
		gap: 4.5rem;
		align-items: start;
		padding-bottom: 0.7rem;
	}

	.identity-column {
		min-width: 0;
		max-width: 100%;
		overflow: hidden;
		position: relative;
		z-index: 2;
	}

	.eyebrow {
		color: #111;
		font-size: 1.38rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.2;
		margin-bottom: 1.25rem;
	}

	.hero-name {
		font-family: "Work Sans", Inter, "Helvetica Neue", Arial, sans-serif;
		font-size: clamp(3rem, 4.7vw, 4.4rem);
		font-weight: 300;
		line-height: 1.05;
		letter-spacing: -0.012em;
		text-wrap: balance;
		display: grid;
		max-width: 100%;
		width: 100%;
		overflow-wrap: normal;
		word-break: normal;
		hyphens: none;
		white-space: normal;
	}

	.hero-line {
		display: block;
	}

	.work-heading {
		font-family: "Work Sans", Inter, "Helvetica Neue", Arial, sans-serif;
		font-size: 1.38rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: #111;
		margin-bottom: 1.2rem;
	}

	.work-column {
		width: 100%;
		min-width: 420px;
		position: relative;
		z-index: 2;
	}

	.decorative-accent {
		position: absolute;
		pointer-events: none;
		user-select: none;
		z-index: 0;
		opacity: 0.94;
		--prox-x: 0px;
		--prox-y: 0px;
		translate: var(--prox-x) var(--prox-y);
		transform: translate3d(0, 0, 0);
		will-change: transform, opacity;
		animation-fill-mode: both;
	}

	.decorative-accent svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.decorative-accent-arc {
		width: clamp(300px, 41vw, 540px);
		top: clamp(0.4rem, 1.6vw, 1.3rem);
		left: clamp(8.8rem, 14.6vw, 16.2rem);
		opacity: 0.96;
		z-index: 1;
		transform: translate3d(0, 0, 0) rotate(-6deg) scale(1);
		animation: accentArcDrift 8.2s cubic-bezier(0.37, 0, 0.63, 1) infinite;
		animation-delay: 220ms;
		--proximity-radius: 260;
		--proximity-strength: 9;
		--proximity-ease: 0.12;
	}

	.decorative-accent-plus {
		width: clamp(20px, 1.8vw, 30px);
		top: -0.62rem;
		right: -0.02rem;
		opacity: 0.96;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(-9deg) scale(1);
		animation: accentPlusPulse 6.1s cubic-bezier(0.37, 0, 0.63, 1) infinite;
		animation-delay: 900ms;
		--proximity-radius: 170;
		--proximity-strength: 11;
		--proximity-ease: 0.17;
	}

	.decorative-accent-capsule {
		width: clamp(96px, 9vw, 136px);
		height: clamp(36px, 3.5vw, 52px);
		border-radius: 999px;
		background: var(--accent-blue-soft);
		top: -0.7rem;
		right: clamp(0.15rem, 1vw, 0.9rem);
		opacity: 0.94;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(-10deg) scale(1);
		animation: accentCapsuleDrift 7.6s cubic-bezier(0.37, 0, 0.63, 1) infinite;
		animation-delay: 500ms;
		--proximity-radius: 210;
		--proximity-strength: 8;
		--proximity-ease: 0.13;
	}

	.decorative-accent-circle {
		width: clamp(28px, 3vw, 46px);
		aspect-ratio: 1;
		border-radius: 999px;
		background: var(--accent-blue);
		top: clamp(2.9rem, 7vw, 5rem);
		left: clamp(2rem, 5vw, 4.8rem);
		opacity: 0.78;
		transform: translate3d(0, 0, 0) scale(1);
		animation: accentCircleFloat 9.4s cubic-bezier(0.22, 0.05, 0.28, 1) infinite;
		animation-delay: 160ms;
		--proximity-radius: 160;
		--proximity-strength: 10;
		--proximity-ease: 0.16;
	}

	.decorative-accent-star-secondary {
		width: clamp(30px, 2.8vw, 44px);
		top: clamp(15.6rem, 21vw, 20.4rem);
		left: clamp(1.2rem, 6vw, 5rem);
		opacity: 0.88;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(-6deg) scale(1);
		animation: accentStarSecondaryFloat 7.4s cubic-bezier(0.3, 0, 0.2, 1) infinite;
		animation-delay: 1200ms;
		--proximity-radius: 150;
		--proximity-strength: 12;
		--proximity-ease: 0.19;
	}

	.decorative-accent-circle-secondary {
		width: clamp(12px, 1.2vw, 18px);
		aspect-ratio: 1;
		border-radius: 999px;
		background: var(--accent-red);
		top: clamp(7.8rem, 12vw, 11rem);
		right: clamp(2.8rem, 4vw, 4rem);
		opacity: 0.76;
		transform: translate3d(0, 0, 0) scale(1);
		animation: accentCircleSecondaryFloat 8.6s cubic-bezier(0.2, 0.05, 0.3, 1) infinite;
		animation-delay: 430ms;
		--proximity-radius: 135;
		--proximity-strength: 8;
		--proximity-ease: 0.16;
	}

	.decorative-accent-oval-secondary {
		width: clamp(44px, 4.8vw, 78px);
		height: clamp(18px, 2.1vw, 28px);
		border-radius: 999px;
		background: var(--accent-green);
		top: clamp(11.6rem, 15.2vw, 14.1rem);
		left: clamp(6.8rem, 11.8vw, 10.8rem);
		opacity: 0.8;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(9deg) scale(1);
		animation: accentOvalFloat 10.3s cubic-bezier(0.25, 0.05, 0.2, 1) infinite;
		animation-delay: 760ms;
		--proximity-radius: 190;
		--proximity-strength: 9;
		--proximity-ease: 0.14;
	}

	.accent-zone-hero:hover .decorative-accent-arc {
		transform: translate3d(0.22rem, -0.12rem, 0) rotate(-4.4deg) scale(1.012);
	}

	.accent-zone-hero:hover .decorative-accent-circle {
		transform: translate3d(0.12rem, -0.12rem, 0) scale(1.04);
	}

	.accent-zone-how:hover .decorative-accent-capsule {
		transform: translate3d(-0.14rem, -0.08rem, 0) rotate(-6deg) scale(1.016);
	}

	.accent-zone-how:hover .decorative-accent-oval-secondary {
		transform: translate3d(-0.14rem, -0.08rem, 0) rotate(12deg) scale(1.03);
	}

	.work-column:hover .decorative-accent-plus {
		transform: translate3d(-0.1rem, -0.06rem, 0) rotate(-3deg) scale(1.02);
	}

	.work-column:hover .decorative-accent-circle-secondary {
		transform: translate3d(-0.04rem, -0.12rem, 0) scale(1.04);
	}

	.work-column:hover .decorative-accent-star-secondary {
		transform: translate3d(0.08rem, -0.12rem, 0) rotate(2deg) scale(1.05);
	}

	.accent-zone-hero:hover .decorative-accent-arc,
	.accent-zone-hero:hover .decorative-accent-circle,
	.accent-zone-how:hover .decorative-accent-capsule,
	.accent-zone-how:hover .decorative-accent-oval-secondary,
	.work-column:hover .decorative-accent-plus,
	.work-column:hover .decorative-accent-circle-secondary,
	.work-column:hover .decorative-accent-star-secondary {
		transition: transform 680ms cubic-bezier(0.2, 0.7, 0.2, 1);
	}

	.project-list {
		--accordion-scale: 0.87;
		border-top: 1px solid var(--line);
	}

	.project-item {
		border-bottom: 1px solid var(--line);
	}

	.project-trigger {
		width: 100%;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		border: 0;
		background: none;
		font: inherit;
		font-size: calc(1.78rem * var(--accordion-scale));
		font-weight: 400;
		line-height: 1.35;
		text-align: left;
		padding: calc(1.85rem * var(--accordion-scale)) 0;
		color: var(--foreground);
		cursor: pointer;
		transition: transform 240ms cubic-bezier(0.2, 0.9, 0.2, 1), color 180ms ease;
		position: relative;
	}

	.project-trigger span:first-child {
		flex: 1;
		min-width: 0;
	}

	.project-trigger:hover {
		transform: translateX(2px);
		color: #070707;
	}

	.project-trigger:focus-visible {
		outline: 2px solid var(--foreground);
		outline-offset: 4px;
	}

	.caret {
		font-size: 1.05rem;
		align-self: center;
