---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const projects = [
	{
		id: 'project-ai-catalog',
		title: 'Vision Prototype: GitLab AI Catalog',
		description:
			'Reframed AI from a chat interface into a discoverable, composable system of capabilities.',
		meta: 'AI platform UX / Concept prototype / 2025',
		link: `${baseUrl}case-studies/ai-catalog-prototype/`
	},
	{
		id: 'project-ai-chat',
		title: 'AI Chat: GitLab Duo & watsonx Code Assistant',
		description:
			'Lead design for IDE-native AI chat at IBM watsonx Code Assistant, plus supporting design on agent-driven Duo Chat patterns at GitLab.',
		meta: 'Shipped product / Developer tools / 2024',
		link: `${baseUrl}case-studies/ai-chat-systems/`
	},
	{
		id: 'project-exploratory',
		title: 'Exploratory AI Work',
		description:
			'Developed forward-looking concepts for agent workflows, productivity systems, and AI-driven developer tooling.',
		meta: 'Product strategy / 0–1 concepts / 2025',
		link: `${baseUrl}case-studies/exploratory-ai-work/`
	}
];
---

<Layout title="Sam Reiss | Portfolio">
	<main class="home-main">
		<div class="decorative-accent decorative-accent-arc-green" aria-hidden="true">
			<svg
				viewBox="0 0 560 250"
				fill="none"
				xmlns="http://www.w3.org/2000/svg"
				focusable="false"
			>
				<path
					d="M38 183C67 104 132 48 218 34C310 19 392 59 445 129L385 177C351 130 293 103 231 114C173 124 130 164 108 219L38 183Z"
					fill="var(--accent-green)"
				></path>
			</svg>
		</div>
		<section class="intro-grid accent-zone accent-zone-hero">
			<div class="decorative-accent decorative-accent-arc-yellow" aria-hidden="true">
				<svg
					viewBox="0 0 760 300"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					focusable="false"
				>
					<path
						d="M48 198C122 76 216 66 286 152C350 233 430 237 500 146C556 76 633 82 712 170"
						stroke="var(--accent-yellow)"
						stroke-width="72"
						stroke-linecap="round"
						stroke-linejoin="round"
					></path>
				</svg>
			</div>
			<div class="decorative-accent decorative-accent-oval-blue" aria-hidden="true"></div>
			<div class="identity-column">
				<p class="eyebrow">Hi, I'm Sam Reiss</p>
				<h1 class="hero-name">
					<span class="hero-line"
						>I'm a Senior Product Designer at GitLab, working on AI powered tools. Formerly
						watsonX at IBM.</span
					>
				</h1>
			</div>

			<div class="work-column">
				<h2 class="work-heading">My Work</h2>
				<div class="decorative-accent decorative-accent-plus" aria-hidden="true">
					<svg
						viewBox="0 0 44 44"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
						focusable="false"
					>
						<path
							d="M22 3C24.9 3 27.2 5.3 27.2 8.2V15.9H34.8C37.7 15.9 40 18.2 40 21.1C40 24 37.7 26.3 34.8 26.3H27.2V34C27.2 36.9 24.9 39.2 22 39.2C19.1 39.2 16.8 36.9 16.8 34V26.3H9.2C6.3 26.3 4 24 4 21.1C4 18.2 6.3 15.9 9.2 15.9H16.8V8.2C16.8 5.3 19.1 3 22 3Z"
							fill="var(--accent-red)"
						></path>
					</svg>
				</div>
				<div class="project-list" data-project-list>
					{
						projects.map((project, index) => (
							<article class="project-item">
								<h3>
									<button
										class="project-trigger"
										type="button"
										aria-expanded="false"
										aria-controls={`${project.id}-panel`}
										id={`${project.id}-button`}
									>
										<span>{project.title}</span>
										<span class="caret" aria-hidden="true">⌃</span>
									</button>
								</h3>
								<div
									class="project-panel"
									id={`${project.id}-panel`}
									role="region"
									aria-labelledby={`${project.id}-button`}
								>
									<div class="project-panel-inner">
										<p class="project-description">{project.description}</p>
										<p class="project-meta">{project.meta}</p>
										<p>
											<a class="project-link" href={project.link}>Read case study</a>
										</p>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="how-grid accent-zone accent-zone-how" aria-labelledby="how-i-work-title">
			<div class="decorative-accent decorative-accent-capsule" aria-hidden="true"></div>
			<div class="decorative-accent decorative-accent-circle" aria-hidden="true"></div>
			<div class="decorative-accent decorative-accent-oval-secondary" aria-hidden="true"></div>
			<div class="decorative-accent decorative-accent-star-secondary" aria-hidden="true">
				<svg
					viewBox="0 0 60 60"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
					focusable="false"
				>
					<path
						d="M30 4L35.2 18.1L50.5 9.5L41.9 24.8L56 30L41.9 35.2L50.5 50.5L35.2 41.9L30 56L24.8 41.9L9.5 50.5L18.1 35.2L4 30L18.1 24.8L9.5 9.5L24.8 18.1L30 4Z"
						fill="var(--accent-red)"
					></path>
				</svg>
			</div>
			<h2 id="how-i-work-title">How I work</h2>
			<div class="how-copy">
				<p>
					I focus on AI product design, prototyping workflows, and developer tools. My
					work turns early product direction into clear interaction models teams can test,
					debate, and ship.
				</p>
				<p>
					I work at the intersection of product direction and execution. I use prototypes to
					make decisions visible early, expose tradeoffs clearly, and help teams align faster
					around what to build.
				</p>
				<p>
					My process stays lightweight: frame the problem, test interaction models quickly,
					then refine the strongest path with engineering constraints in view.
				</p>
			</div>
		</section>
	</main>
</Layout>

<script>
	const projectList = document.querySelector('[data-project-list]');
	const triggers = projectList?.querySelectorAll('.project-trigger') ?? [];

	const closeAllPanels = () => {
		triggers.forEach((trigger) => {
			trigger.setAttribute('aria-expanded', 'false');
			const panelId = trigger.getAttribute('aria-controls');
			const panel = panelId ? document.getElementById(panelId) : null;
			panel?.classList.remove('open');
		});
	};

	triggers.forEach((trigger) => {
		trigger.addEventListener('click', () => {
			const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
			closeAllPanels();

			if (!isExpanded) {
				trigger.setAttribute('aria-expanded', 'true');
				const panelId = trigger.getAttribute('aria-controls');
				const panel = panelId ? document.getElementById(panelId) : null;
				panel?.classList.add('open');
			}
		});
	});

	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const prefersFinePointer = window.matchMedia('(pointer: fine)').matches;
	const prefersHover = window.matchMedia('(hover: hover)').matches;
	const query = new URLSearchParams(window.location.search);
	const enableMotionDebug =
		(window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') &&
		query.has('motionDebug');
	const densityMode = query.get('density');
	const proximityOverride = query.get('proximity');

	if (enableMotionDebug) {
		document.documentElement.classList.add('motion-debug');
	}

	const homeMain = document.querySelector('.home-main');
	if (homeMain && (densityMode === 'full' || densityMode === 'reduced')) {
		homeMain.setAttribute('data-accent-density', densityMode);
	}

	const proximityEnabled =
		prefersFinePointer &&
		prefersHover &&
		(enableMotionDebug || !reduceMotion) &&
		proximityOverride !== '0';

	if (homeMain && proximityEnabled) {
		const accents = [...homeMain.querySelectorAll('.decorative-accent')].filter(
			(el) =>
				!el.classList.contains('decorative-accent-plus') &&
				!el.classList.contains('decorative-accent-star-secondary')
		);
		const accentState = accents.map((element) => {
			const style = window.getComputedStyle(element);
			const radius = Number.parseFloat(style.getPropertyValue('--proximity-radius')) || 180;
			const strength = Number.parseFloat(style.getPropertyValue('--proximity-strength')) || 7;
			const ease = Number.parseFloat(style.getPropertyValue('--proximity-ease')) || 0.14;
			return {
				element,
				radius,
				strength,
				ease,
				centerX: 0,
				centerY: 0,
				currentX: 0,
				currentY: 0
			};
		});

		const pointer = { x: 0, y: 0, active: false };
		let rafId = 0;
		let resizeFlushRaf = 0;

		let pointerMoveRaf = 0;
		let pendingPointerX = 0;
		let pendingPointerY = 0;

		const refreshCenters = () => {
			accentState.forEach((accent) => {
				const rect = accent.element.getBoundingClientRect();
				accent.centerX = rect.left + rect.width * 0.5;
				accent.centerY = rect.top + rect.height * 0.5;
			});
		};

		const tick = () => {
			let hasMovement = false;

			accentState.forEach((accent) => {
				let targetX = 0;
				let targetY = 0;

				if (pointer.active) {
					const dx = accent.centerX - pointer.x;
					const dy = accent.centerY - pointer.y;
					const distance = Math.hypot(dx, dy);

					if (distance < accent.radius && distance > 0.001) {
						const normalized = 1 - distance / accent.radius;
						const push = normalized * accent.strength;
						targetX = (dx / distance) * push;
						targetY = (dy / distance) * push;
					}
				}

				accent.currentX += (targetX - accent.currentX) * accent.ease;
				accent.currentY += (targetY - accent.currentY) * accent.ease;
				accent.element.style.setProperty('--prox-x', `${accent.currentX.toFixed(2)}px`);
				accent.element.style.setProperty('--prox-y', `${accent.currentY.toFixed(2)}px`);

				if (
					Math.abs(accent.currentX - targetX) > 0.05 ||
					Math.abs(accent.currentY - targetY) > 0.05
				) {
					hasMovement = true;
				}
			});

			if (hasMovement) {
				rafId = window.requestAnimationFrame(tick);
			} else {
				rafId = 0;
			}
		};

		const requestTick = () => {
			if (!rafId) rafId = window.requestAnimationFrame(tick);
		};

		const onPointerMove = (event) => {
			pointer.active = true;
			pendingPointerX = event.clientX;
			pendingPointerY = event.clientY;
			if (pointerMoveRaf !== 0) return;
			pointerMoveRaf = window.requestAnimationFrame(() => {
				pointerMoveRaf = 0;
				pointer.x = pendingPointerX;
				pointer.y = pendingPointerY;
				requestTick();
			});
		};

		const onPointerLeave = () => {
			pointer.active = false;
			requestTick();
		};

		refreshCenters();
		window.addEventListener('pointermove', onPointerMove, { passive: true });
		window.addEventListener('pointerleave', onPointerLeave, { passive: true });
		window.addEventListener('resize', () => {
			if (resizeFlushRaf !== 0) return;
			resizeFlushRaf = window.requestAnimationFrame(() => {
				resizeFlushRaf = 0;
				refreshCenters();
				requestTick();
			});
		}, { passive: true });
	}
</script>

<style>
	:root {
		--accent-green: #009f5a;
		--accent-red: #ff3b30;
		--accent-blue: #0b1b3a;
		--accent-blue-soft: #3f5f9a;
		--accent-yellow: #ffd400;
		--accent-pink: #f3a8cf;
		--accent-orange: #ff5a1f;
		--accent-cream: #f6f1e6;
		--accent-blue-light: #8bb9ff;
	}

	.home-main {
		width: min(1320px, calc(100% - 6rem));
		margin: 0 auto;
		position: relative;
		z-index: 0;
	}

	.home-main[data-accent-density='reduced'] .decorative-accent-circle,
	.home-main[data-accent-density='reduced'] .decorative-accent-star-secondary,
	.home-main[data-accent-density='reduced'] .decorative-accent-oval-secondary {
		display: none;
	}

	.accent-zone {
		position: relative;
		isolation: isolate;
	}

	@media (pointer: coarse) {
		.accent-zone {
			isolation: auto;
		}
	}

	.intro-grid > :not(.decorative-accent),
	.how-grid > :not(.decorative-accent),
	.work-column > :not(.decorative-accent) {
		position: relative;
		z-index: 2;
	}

	.intro-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(420px, 0.75fr);
		gap: 4.5rem;
		align-items: start;
		padding-bottom: 0.7rem;
		position: relative;
		z-index: 2;
	}

	.identity-column {
		min-width: 0;
		max-width: 100%;
		overflow: hidden;
		position: relative;
		z-index: 2;
	}

	.eyebrow {
		color: #111;
		font-size: 1.38rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.2;
		margin-bottom: 1.25rem;
	}

	.hero-name {
		font-family: "Work Sans", Inter, "Helvetica Neue", Arial, sans-serif;
		font-size: clamp(3.75rem, 5.875vw, 5.5rem);
		font-weight: 300;
		line-height: 1.05;
		letter-spacing: -0.012em;
		text-wrap: balance;
		display: grid;
		max-width: 100%;
		width: 100%;
		overflow-wrap: normal;
		word-break: normal;
		hyphens: none;
		white-space: normal;
	}

	.hero-line {
		display: block;
		font-family: "Instrument Serif", Georgia, "Times New Roman", serif;
		font-weight: 400;
	}

	.work-heading {
		font-family: "Work Sans", Inter, "Helvetica Neue", Arial, sans-serif;
		font-size: 1.38rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: #111;
		margin-bottom: 1.2rem;
	}

	.work-column {
		width: 100%;
		min-width: 420px;
		position: relative;
		z-index: 2;
	}

	.decorative-accent {
		position: absolute;
		pointer-events: none;
		user-select: none;
		z-index: 0;
		opacity: 0.94;
		--prox-x: 0px;
		--prox-y: 0px;
		translate: var(--prox-x) var(--prox-y);
		transform: translate3d(0, 0, 0);
		animation-fill-mode: both;
	}

	.decorative-accent svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.decorative-accent-arc-green {
		left: auto;
		top: auto;
		right: clamp(-64px, -5vw, -6px);
		bottom: calc(120px + clamp(-110px, -18vh, -28px));
		width: clamp(187px, 27.2vw, 323px);
		margin-left: 0;
		margin-top: 0;
		opacity: 0.74;
		z-index: 0;
		transform-origin: center;
		transform: translate3d(-10px, 4px, 0) rotate(3deg) scale(0.99);
		animation: accentGreenArchDrift 13.8s linear infinite;
		animation-delay: -2.8s;
		--proximity-radius: 284;
		--proximity-strength: 11;
		--proximity-ease: 0.11;
	}

	.decorative-accent-arc-yellow {
		width: clamp(366px, 49.3vw, 714px);
		top: clamp(0.2rem, 1.1vw, 1rem);
		left: clamp(7.2rem, 11.8vw, 12.8rem);
		opacity: 0.93;
		z-index: 1;
		transform-origin: center;
		transform: translate3d(-9px, 6px, 0) rotate(-32.8deg) scale(1);
		animation: accentYellowSquiggleDrift 17.7s linear infinite;
		animation-delay: -1.1s;
		--proximity-radius: 302;
		--proximity-strength: 12;
		--proximity-ease: 0.09;
	}

	.decorative-accent-plus {
		width: clamp(37px, 3.1vw, 53px);
		top: -0.62rem;
		right: -0.02rem;
		opacity: 0.96;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(-9deg) scale(1);
		animation: accentPlusPulse 18s linear infinite;
		animation-delay: 900ms;
		--proximity-radius: 170;
		--proximity-strength: 11;
		--proximity-ease: 0.17;
	}

	.decorative-accent-capsule {
		width: clamp(108px, 11.8vw, 184px);
		height: clamp(66px, 7vw, 108px);
		border-radius: 50%;
		background: var(--accent-pink);
		top: -0.7rem;
		right: clamp(0.15rem, 1vw, 0.9rem);
		opacity: 0.88;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(-10deg) scale(1);
		animation: accentCapsuleDrift 11.9s linear infinite;
		animation-delay: -3.6s;
		--proximity-radius: 226;
		--proximity-strength: 10;
		--proximity-ease: 0.12;
	}

	.decorative-accent-circle {
		width: clamp(20px, 2.6vw, 58px);
		aspect-ratio: 1;
		border-radius: 999px;
		background: var(--accent-blue-light);
		top: clamp(4.1rem, 8.1vw, 6.5rem);
		left: clamp(3.5rem, 7.4vw, 6.8rem);
		opacity: 0.78;
		transform: translate3d(0, 0, 0) scale(1);
		animation: accentCircleFloat 15.6s linear infinite;
		animation-delay: -4.2s;
		--proximity-radius: 178;
		--proximity-strength: 9;
		--proximity-ease: 0.13;
	}

	.decorative-accent-oval-blue {
		width: clamp(52px, 5.6vw, 108px);
		height: clamp(18px, 2.2vw, 34px);
		border-radius: 999px;
		background: var(--accent-blue-light);
		top: clamp(-0.7rem, 0.2vw, 0.25rem);
		left: clamp(10rem, 16.1vw, 15.2rem);
		opacity: 0.78;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(-10deg) scale(1);
		animation: accentOvalBlueFloat 12.4s linear infinite;
		animation-delay: -0.7s;
		--proximity-radius: 206;
		--proximity-strength: 8;
		--proximity-ease: 0.18;
	}

	.decorative-accent-star-secondary {
		width: clamp(42px, 5.2vw, 86px);
		top: clamp(12.1rem, 16.5vw, 15.2rem);
		left: clamp(2.4rem, 7.2vw, 5.8rem);
		opacity: 0.9;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(-6deg) scale(1);
		animation: accentStarSecondaryFloat 20s linear infinite;
		animation-delay: 1200ms;
		--proximity-radius: 150;
		--proximity-strength: 12;
		--proximity-ease: 0.19;
	}

	.decorative-accent-oval-secondary {
		width: clamp(66px, 7.8vw, 142px);
		height: clamp(22px, 2.8vw, 40px);
		border-radius: 999px;
		background: var(--accent-orange);
		top: clamp(11.6rem, 15.2vw, 14.1rem);
		left: clamp(6.8rem, 11.8vw, 10.8rem);
		opacity: 0.86;
		transform-origin: center;
		transform: translate3d(0, 0, 0) rotate(9deg) scale(1);
		animation: accentOvalFloat 16.2s linear infinite;
		animation-delay: -5.4s;
		--proximity-radius: 238;
		--proximity-strength: 7;
		--proximity-ease: 0.15;
	}

	/* Hover nudges fight keyframe transforms on touch (sticky :hover); keep for fine pointers only. */
	@media (hover: hover) and (pointer: fine) {
		.accent-zone-hero:hover .decorative-accent-oval-blue {
			transform: translate3d(0.14rem, -0.09rem, 0) rotate(-6deg) scale(1.04);
		}

		.accent-zone-how:hover .decorative-accent-circle {
			transform: translate3d(0.1rem, -0.12rem, 0) scale(1.04);
		}

		.accent-zone-how:hover .decorative-accent-capsule {
			transform: translate3d(-0.14rem, -0.08rem, 0) rotate(-6deg) scale(1.016);
		}

		.accent-zone-how:hover .decorative-accent-oval-secondary {
			transform: translate3d(-0.14rem, -0.08rem, 0) rotate(12deg) scale(1.03);
		}

		.work-column:hover .decorative-accent-plus {
			transform: translate3d(-0.1rem, -0.06rem, 0) rotate(-3deg) scale(1.02);
		}

		.work-column:hover .decorative-accent-star-secondary {
			transform: translate3d(0.08rem, -0.12rem, 0) rotate(2deg) scale(1.05);
		}

		.home-main:hover .decorative-accent-arc-green {
			transform: translate3d(calc(0.35rem - 10px), calc(-0.35rem + 4px), 0) rotate(8deg) scale(1.02);
		}

		.accent-zone-hero:hover .decorative-accent-arc-yellow {
			transform: translate3d(calc(0.22rem - 9px), calc(-0.12rem + 6px), 0) rotate(-31.6deg)
				scale(1.012);
		}

		.home-main:hover .decorative-accent-arc-green,
		.accent-zone-hero:hover .decorative-accent-arc-yellow,
		.accent-zone-hero:hover .decorative-accent-oval-blue,
		.accent-zone-how:hover .decorative-accent-circle,
		.accent-zone-how:hover .decorative-accent-capsule,
		.accent-zone-how:hover .decorative-accent-oval-secondary,
		.work-column:hover .decorative-accent-plus,
		.work-column:hover .decorative-accent-star-secondary {
			transition: transform 680ms cubic-bezier(0.2, 0.7, 0.2, 1);
		}
	}

	.project-list {
		--accordion-scale: 0.87;
		border-top: 1px solid var(--line);
	}

	.project-item {
		border-bottom: 1px solid var(--line);
	}

	.project-trigger {
		width: 100%;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		border: 0;
		background: none;
		font: inherit;
		font-size: calc(1.78rem * var(--accordion-scale));
		font-weight: 400;
