---
interface Props {
	title: string;
	overview: string;
	problem: string;
	myRole: string;
	workflow: string;
	designDecisions: string[];
	outcome: string;
}

const {
	title,
	overview,
	problem,
	myRole,
	workflow,
	designDecisions,
	outcome
} = Astro.props;
---

<article class="case-study">
	<header class="case-study-header">
		<p class="section-kicker">Case Study</p>
		<h1>{title}</h1>
	</header>

	<section class="case-section">
		<h2>Overview</h2>
		<p>{overview}</p>
	</section>

	<slot name="prototype" />

	<section class="case-section">
		<h2>Problem</h2>
		<p>{problem}</p>
	</section>

	<section class="case-section">
		<h2>My Role</h2>
		<p>{myRole}</p>
	</section>

	<section class="case-section">
		<h2>AI-assisted workflow</h2>
		<p>{workflow}</p>
	</section>

	<section class="case-section">
		<h2>Key design decisions</h2>
		<ul>
			{designDecisions.map((item) => <li>{item}</li>)}
		</ul>
	</section>

	<section class="case-section">
		<h2>Outcome</h2>
		<p>{outcome}</p>
	</section>
</article>

<style>
	.case-study {
		max-width: 980px;
		margin-inline: auto;
		font-family: "Work Sans", Inter, "Helvetica Neue", Arial, sans-serif;
	}

	.case-study-header {
		display: grid;
		grid-template-columns: minmax(170px, 0.46fr) 1fr;
		gap: 2.5rem;
		padding-bottom: 2.9rem;
		border-bottom: 1px solid var(--line);
		margin-bottom: 0.4rem;
	}

	.section-kicker {
		grid-column: 1;
		font-size: 1.38rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: #111;
		margin-bottom: 0;
		padding-top: 0.58rem;
	}

	.case-study-header h1 {
		grid-column: 2;
		font-size: clamp(2.7rem, 4.7vw, 4.4rem);
		line-height: 1.02;
		letter-spacing: -0.014em;
		max-width: 14ch;
		font-weight: 300;
	}

	.case-section {
		display: grid;
		grid-template-columns: minmax(170px, 0.46fr) 1fr;
		gap: 0.82rem 2.5rem;
		padding: 2.15rem 0;
		border-bottom: 1px solid var(--line);
	}

	.case-section h2 {
		font-size: 1.38rem;
		line-height: 1.2;
		letter-spacing: -0.01em;
		color: #111;
		font-weight: 600;
		padding-top: 0.35rem;
	}

	.case-section p,
	.case-section li {
		color: #242424;
		font-size: clamp(1.03rem, 1.46vw, 1.2rem);
		line-height: 1.66;
		letter-spacing: -0.008em;
	}

	.case-section ul {
		margin: 0;
		padding-left: 1.15rem;
		display: grid;
		gap: 0.78rem;
		color: #242424;
	}

	@media (max-width: 1024px) {
		.case-study-header,
		.case-section {
			grid-template-columns: minmax(145px, 0.4fr) 1fr;
			gap: 0.78rem 1.9rem;
		}
	}

	@media (max-width: 880px) {
		.case-study-header {
			grid-template-columns: 1fr;
			gap: 0.75rem;
		}

		.section-kicker {
			padding-top: 0;
		}

		.case-study-header h1,
		.section-kicker {
			grid-column: auto;
		}

		.case-section {
			grid-template-columns: 1fr;
			gap: 0.65rem;
			padding: 1.4rem 0;
		}

		.case-section h2 {
			padding-top: 0;
		}
	}
</style>
